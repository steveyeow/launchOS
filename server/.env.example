# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/getu_ai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Browser automation
USE_LOCAL_BROWSER=true           # Set to false in production to use Steel.dev
STEEL_API_KEY=                   # Required when USE_LOCAL_BROWSER=false

# Twitter OAuth (for write actions)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Security
ENCRYPTION_KEY=32-char-random-string-for-aes256

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
