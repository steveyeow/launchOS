# Frontend environment variables
# VITE_API_URL is only needed for production builds (e.g. https://api.getu.ai).
# In development, leave it unset — Vite proxies /api requests to the backend automatically.
# VITE_API_URL=https://api.example.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
